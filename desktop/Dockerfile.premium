FROM lscr.io/linuxserver/webtop:ubuntu-xfce@sha256:dc752c7ac78278e39b5cd32e85cbfe7cfc7f68c32f03f06bf91bcb1af1b7737d

RUN rm -f /etc/apt/sources.list.d/nodesource.sources && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        apt-utils \
        arc-theme \
        build-essential \
        ca-certificates \
        curl \
        desktop-file-utils \
        fonts-inter \
        gdebi-core \
        git \
        gnupg \
        gvfs \
        gvfs-backends \
        htop \
        jq \
        nano \
        nodejs \
        papirus-icon-theme \
        python3 \
        python3-pip \
        python3-venv \
        software-properties-common \
        thunar-volman \
        tumbler \
        unzip \
        wget \
        xdg-user-dirs \
        xdg-desktop-portal \
        xdg-desktop-portal-gtk \
        xdg-utils \
        file-roller \
        xfce4-whiskermenu-plugin && \
    wget -qO /tmp/vscodium.gpg \
        https://gitlab.com/paulcarroty/vscodium-deb-rpm-repo/raw/master/pub.gpg && \
    gpg --dearmor \
        --output /usr/share/keyrings/vscodium-archive-keyring.gpg \
        /tmp/vscodium.gpg && \
    rm /tmp/vscodium.gpg && \
    printf '%s\n' \
        'Types: deb' \
        'URIs: https://download.vscodium.com/debs' \
        'Suites: vscodium' \
        'Components: main' \
        'Architectures: amd64 arm64' \
        'Signed-by: /usr/share/keyrings/vscodium-archive-keyring.gpg' \
        > /etc/apt/sources.list.d/vscodium.sources && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        codium && \
    rm -rf /var/lib/apt/lists/*

COPY --chown=root:root assets/ /opt/nexus-desktop/assets/
COPY --chown=root:root scripts/apply-nexus-theme.sh /custom-cont-init.d/apply-nexus-theme.sh

RUN chmod 0755 /custom-cont-init.d/apply-nexus-theme.sh
